[
    {
        "number": 1,
        "season": "EASTER",
        "SUNDAY": {
            "collect": "Almighty God, who through your only-begotten Son Jesus Christ overcame death and opened to us the gate of everlasting life: Grant that we, who celebrate with joy the day of the Lord's resurrection, may be raised from the death of sin by your life-giving Spirit; through Jesus Christ our Lord, who lives and reigns with you and the Holy Spirit, one God, now and for ever. Amen.",
            "morning": {
                "psalter": "148, 149, 150",
                "readings": [
                    "Exod. 12:1-14",
                    "John 1:1-18"
                ]
            },
            "evening": {
                "psalter": "113, 114 or 118",
                "readings": [
                    "Isa. 51:9-11",
                    "Luke 24:13-35, or John 20:19-23"
                ]
            },
            "rank": "PRINCIPAL",
            "name": "Easter Sunday"
        },
        "MONDAY": {
            "year_1_readings": [
                "Jonah 2:1-9",
                "Acts 2:14, 22-32",
                "John 14:1-14"
            ],
            "year_2_readings": [
                "Exod. 12:14-27",
                "1 Cor. 15:1-11",
                "Mark 16:1-8"
            ],
            "morning": {
                "psalter": "93, 98"
            },
            "evening": {
                "psalter": "66"
            },
            "collect": "Grant, we pray, Almighty God, that we who celebrate with awe the Paschal feast may be found worthy to attain to everlasting joys; through Jesus Christ our Lord, who lives and reigns with you and the Holy Spirit, one God, now and for ever. Amen.",
            "name": "Monday of the Octave of Easter",
            "rank": "PRINCIPAL"
        },
        "TUESDAY": {
            "year_1_readings": [
                "Isa. 30:18-21",
                "Acts 2:36-41(42-47)",
                "John 14:15-31"
            ],
            "year_2_readings": [
                "Exod. 12:28-39",
                "1 Cor. 15:12-28",
                "Mark 16:9-20"
            ],
            "morning": {
                "psalter": "103"
            },
            "evening": {
                "psalter": "111, 114"
            },
            "collect": "O God, who by the glorious resurrection of your Son Jesus Christ destroyed death and brought life and immortality to light: Grant that we, who have been raised with him, may abide in his presence and rejoice in the hope of eternal glory; through Jesus Christ our Lord, to whom, with you and the Holy Spirit, be dominion and praise for ever and ever. Amen.",
            "name": "Tuesday of the Octave of Easter",
            "rank": "PRINCIPAL"
        },
        "WEDNESDAY": {
            "year_1_readings": [
                "Micah 7:7-15",
                "Acts 3:1-10",
                "John 15:1-11"
            ],
            "year_2_readings": [
                "Exod. 12:40-51",
                "1 Cor. 15:(29)30-41",
                "Matt. 28:1-16"
            ],
            "morning": {
                "psalter": "97, 99"
            },
            "evening": {
                "psalter": "115"
            },
            "collect": "O God, whose blessed Son made himself known to his disciples in the breaking of bread: Open the eyes of our faith, that we may behold him in all his redeeming work; who lives and reigns with you, in the unity of the Holy Spirit, one God, now and for ever. Amen.",
            "name": "Wednesday of the Octave of Easter",
            "rank": "PRINCIPAL"
        },
        "THURSDAY": {
            "year_1_readings": [
                "Ezek. 37:1-14",
                "Acts 3:11-26",
                "John 15:12-27"
            ],
            "year_2_readings": [
                "Exod. 13:3-10",
                "1 Cor. 15:41-50",
                "Matt. 28:16-20"
            ],
            "morning": {
                "psalter": "146, 147"
            },
            "evening": {
                "psalter": "148, 149"
            },
            "collect": "Almighty and everlasting God, who in the Paschal mystery established the new covenant of reconciliation: Grant that all who have been reborn into the fellowship of Christ's Body may show forth in their lives what they profess by their faith; through Jesus Christ our Lord, who lives and reigns with you and the Holy Spirit, one God, for ever and ever. Amen.",
            "name": "Thursday of the Octave of Easter",
            "rank": "PRINCIPAL"
        },
        "FRIDAY": {
            "year_1_readings": [
                "Dan. 12:1-4, 13",
                "Acts 4:1-12",
                "John 16:1-15"
            ],
            "year_2_readings": [
                "Exod. 13:1-2, 11-16",
                "1 Cor. 15:51-58",
                "Luke 24:1-12"
            ],
            "morning": {
                "psalter": "136"
            },
            "evening": {
                "psalter": "118"
            },
            "collect": "Almighty Father, who gave your only Son to die for our sins and to rise for our justification: Give us grace so to put away the leaven of malice and wickedness, that we may always serve you in pureness of living and truth; through Jesus Christ your Son our Lord, who lives and reigns with you and the Holy Spirit, one God, now and for ever. Amen.",
            "name": "Friday of the Octave of Easter",
            "rank": "PRINCIPAL"
        },
        "SATURDAY": {
            "year_1_readings": [
                "Isa. 25:1-9",
                "Acts 4:13-21(22-31)",
                "John 16:16-33"
            ],
            "year_2_readings": [
                "Exod 13:17--14:4",
                "2 Cor. 4:16--5:10",
                "Mark 12:18-27"
            ],
            "morning": {
                "psalter": "145"
            },
            "evening": {
                "psalter": "104"
            },
            "collect": "We thank you, heavenly Father, that you have delivered us from the dominion of sin and death and brought us into the kingdom of your Son; and we pray that, as by his death he has recalled us to life, so by his love he may raise us to eternal joys; who lives and reigns with you, in the unity of the Holy Spirit, one God, now and forever. Amen.",
            "name": "Saturday of the Octave of Easter",
            "rank": "PRINCIPAL"
        }
    },
